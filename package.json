{
  "name": "ashraf-portfolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:deploy": "ng build --configuration production && node scripts/build-deploy.mjs",
    "clean:deploy": "rm -rf deploy && mkdir -p deploy",
    "zip:deploy": "rm -f deploy/ashraf-portfolio-deploy.zip ashraf-portfolio-deploy.zip && cd deploy && zip -qr ../ashraf-portfolio-deploy.zip . && mv ../ashraf-portfolio-deploy.zip ashraf-portfolio-deploy.zip",
    "deploy:local": "npm run build:prod && npm run clean:deploy && cp -R dist/ashraf-portfolio/browser/. deploy/ && npm run zip:deploy",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.31",
    "@angular/cli": "^20.3.31",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
